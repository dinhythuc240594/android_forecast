<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/txtDailyDay"
        android:layout_width="88dp"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="Hôm nay" />

    <LinearLayout
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/main_forecast_rain_symbol"
            android:textColor="#D6FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/txtDailyPop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:textColor="#D6FFFFFF"
            android:textSize="13sp"
            tools:text="4%" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imgDailyDay"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:contentDescription="@string/main_forecast_icon_day_cd"
        android:scaleType="fitCenter" />

    <ImageView
        android:id="@+id/imgDailyNight"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:contentDescription="@string/main_forecast_icon_night_cd"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/txtDailyTemps"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:gravity="end"
        android:textColor="#E6FFFFFF"
        android:textSize="15sp"
        tools:text="34° 25°" />
</LinearLayout>
